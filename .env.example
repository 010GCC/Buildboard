# Buildboard backend environment example.
# Copy to `.env` and fill in real values locally. Never commit `.env` or any
# real secret. The values below are placeholders, not credentials.

# Optional Ollama-compatible AI provider used by POST /api/generate-plan.
# When OLLAMA_BASE_URL is unset, the /api/generate-plan route returns 503 and
# the rest of the prompt-backend workflow continues to work without AI calls.

# Base URL of your Ollama-compatible server (local or hosted). Required to
# enable runtime plan generation. Example: http://127.0.0.1:11434
OLLAMA_BASE_URL=

# Optional Bearer token forwarded to the Ollama-compatible endpoint. Only the
# backend reads this value; it is never exposed to the browser.
OLLAMA_API_KEY=

# Optional default model name (e.g. llama3, qwen2.5, mistral). When omitted,
# the client's selected model name is forwarded; if neither is set the server
# falls back to "llama3".
OLLAMA_MODEL=

# Optional server port (defaults to 5000).
PORT=
